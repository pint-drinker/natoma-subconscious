# Subconscious API key — get one at https://subconscious.dev
SUBCONSCIOUS_API_KEY=sky_REPLACE_ME

# Optional overrides
# SUBCONSCIOUS_BASE_URL=https://api.subconscious.dev/v1
# SUBCONSCIOUS_MODEL=subconscious/tim-qwen3.6-27b
# SUBCONSCIOUS_ENABLE_THINKING=1   # enable the model's thinking step (off by default)

# ---------------------------------------------------------------------------
# Natoma-managed MCP servers (proxied through natoma.app).
# Add a NATOMA_MCP_<NAME>_URL / NATOMA_MCP_<NAME>_KEY pair for each one.
# <NAME> is just a label — pick whatever helps you read your config.
# ---------------------------------------------------------------------------

# NATOMA_MCP_GMAIL_URL=https://subconscious.mcp.natoma.app/v2/user/my-connections/gmail/mcp
# NATOMA_MCP_GMAIL_KEY=

# NATOMA_MCP_BRAVE_URL=https://subconscious.mcp.natoma.app/v2/user/my-connections/brave/mcp
# NATOMA_MCP_BRAVE_KEY=

# ---------------------------------------------------------------------------
# Direct MCP servers — connect straight to a service's own MCP endpoint.
# Add a MCP_<NAME>_URL / MCP_<NAME>_KEY pair for each one.
# Auth is sent as "Authorization: Bearer <key>".
# ---------------------------------------------------------------------------

# Linear — generate an API key at https://linear.app/settings/account/security
# MCP_LINEAR_URL=https://mcp.linear.app/mcp
# MCP_LINEAR_KEY=

# Auth header override for Natoma MCPs. Defaults to "Authorization" + "Bearer ".
# Leave NATOMA_AUTH_SCHEME empty to send the raw key with no prefix.
# NATOMA_AUTH_HEADER=Authorization
# NATOMA_AUTH_SCHEME=Bearer
