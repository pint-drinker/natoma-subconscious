# Subconscious API key — get one at https://subconscious.dev
SUBCONSCIOUS_API_KEY=sky_REPLACE_ME

# Optional overrides
# SUBCONSCIOUS_BASE_URL=https://api.subconscious.dev/v1
# SUBCONSCIOUS_MODEL=subconscious/tim-qwen3.6-27b
# SUBCONSCIOUS_ENABLE_THINKING=1   # enable the model's thinking step (off by default)

# Natoma MCP servers. Add a _URL/_KEY pair for each MCP you want to enable.
# The agent auto-discovers any NATOMA_MCP_<NAME>_URL with a matching _KEY.
# <NAME> is just a label — pick whatever helps you read your config.

NATOMA_MCP_GMAIL_URL=https://gmail.mcp.natoma.app/v2/user/my-connections/mcp
NATOMA_MCP_GMAIL_KEY=

# NATOMA_MCP_LINEAR_URL=https://linear.mcp.natoma.app/v2/user/my-connections/mcp
# NATOMA_MCP_LINEAR_KEY=

# NATOMA_MCP_BRAVE_URL=https://brave.mcp.natoma.app/v2/user/my-connections/mcp
# NATOMA_MCP_BRAVE_KEY=

# Auth header override. Defaults to "Authorization" + "Bearer ".
# If Natoma uses a different scheme, set these. Leave NATOMA_AUTH_SCHEME
# empty to send the raw key with no prefix.
# NATOMA_AUTH_HEADER=Authorization
# NATOMA_AUTH_SCHEME=Bearer
